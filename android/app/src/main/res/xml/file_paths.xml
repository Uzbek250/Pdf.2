<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- getApplicationDocumentsDirectory() shu yerga mos keladi -->
    <files-path name="app_documents" path="." />
    <cache-path name="app_cache" path="." />
    <external-files-path name="external_files" path="." />
    <!-- Qurilmaning umumiy Download papkasi (/storage/emulated/0/Download) —
         tarjima natijasi endi shu yerga saqlanadi, shuning uchun
         FileProvider bu yo'lni ham "tanish" (recognized) deb bilishi
         kerak, aks holda `open_file` orqali ochishda ruxsat xatosi
         chiqishi mumkin. -->
    <external-path name="external_storage_root" path="." />
</paths>
